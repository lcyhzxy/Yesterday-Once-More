# Time Revival - AI Photo Video Generation System
# Environment Variables Configuration Example
#
# Copy this file to .env and fill in the values

# Flask Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# API Configuration
API_PREFIX=/api

# Video Generation Defaults
DEFAULT_DURATION=5
DEFAULT_FPS=30
DEFAULT_MOTION_MODE=breathing
DEFAULT_STYLE=warm_memories
DEFAULT_INTENSITY=0.5

# Video Generation Limits
MAX_DURATION=30
MIN_DURATION=1
MAX_FPS=60
MIN_FPS=15
MAX_RESOLUTION_WIDTH=1920
MAX_RESOLUTION_HEIGHT=1080
MIN_RESOLUTION_WIDTH=640
MIN_RESOLUTION_HEIGHT=480

# File Upload Settings
MAX_CONTENT_LENGTH=52428800

# Directory Paths (leave empty for default)
# UPLOAD_DIR=
# OUTPUT_DIR=
# TEMP_DIR=

# CORS Configuration
CORS_ENABLED=true
CORS_ORIGINS=*

# Rate Limiting (optional)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
